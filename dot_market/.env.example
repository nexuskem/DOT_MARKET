# DOT MARKET — Environment Variables
# Copy this file to .env and fill in your values.
# The app works without any API keys (yfinance is free).

# Flask settings
FLASK_DEBUG=true
PORT=5000

# Optional: Alpha Vantage key for extended data (not required)
# ALPHA_VANTAGE_KEY=your_key_here

# Optional: set to false in production
FLASK_ENV=development
